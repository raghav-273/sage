# =========================
# OpenAI (optional)
# =========================
OPENAI_API_KEY=your_api_key_here

# =========================
# Database
# =========================
DATABASE_URL=postgres://sage_user:change_me@db:5432/sage

# =========================
# Redis
# =========================
REDIS_URL=redis://redis:6379/0
DJANGO_CACHE_URL=redis://redis:6379/1

# =========================
# Django
# =========================
DJANGO_SECRET_KEY=your_django_secret_key_here
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1

# Cookie security
# Set to False when running over plain HTTP (local development).
# Set to True when running behind HTTPS in production.
#SESSION_COOKIE_SECURE=False (not needed for local development)
#CSRF_COOKIE_SECURE=False (not needed for local development)

# =========================
# Celery
# =========================
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# =========================
# Logging
# =========================
DJANGO_LOG_LEVEL=INFO

# =========================
# Generation
# =========================
GENERATION_PROVIDER=gemini
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash
GEMINI_FALLBACK_MODEL=gemini-2.5-flash-lite
GEMINI_REQUEST_TIMEOUT_SECONDS=25

# =========================
# Login Security
# =========================
LOGIN_CHALLENGE_FAILURE_THRESHOLD=5
LOGIN_CHALLENGE_WINDOW_SECONDS=900
LOGIN_CHALLENGE_TOKEN_MAX_AGE=300

DJANGO_RUN_SERVER_MODE=gunicorn
GUNICORN_TLS_CERTFILE=/app/certs/localhost.crt
GUNICORN_TLS_KEYFILE=/app/certs/localhost.key
CSRF_TRUSTED_ORIGINS=http://localhost:8000,https://localhost:8443

# Now that real TLS exists, remove or set these back to True/unset so
# cookies are properly flagged Secure on the HTTPS connection:
# SESSION_COOKIE_SECURE=False   <- remove this line
# CSRF_COOKIE_SECURE=False      <- remove this line


# Cloudflare Turnstile — TEST keys by default. Get real keys (free) at
# dash.cloudflare.com -> Turnstile before any real demo: test keys give
# zero actual bot protection.
TURNSTILE_SITE_KEY=1x00000000000000000000AA
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA